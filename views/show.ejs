<div class="container mx-auto py-16 px-4 max-w-4xl">

  <div class="relative rounded-2xl border border-white/10 shadow-2xl overflow-hidden">

    <div class="absolute inset-0 bg-black/20 backdrop-blur-md"></div>

    <div class="relative p-10 flex flex-col gap-6">

      <div class="flex justify-between items-center">

        <h1 class="text-3xl font-bold"><%= filename %></h1>

        <div class="flex gap-3">

          <a href="/edit/<%= id %>" 
            class="bg-yellow-500/80 px-5 py-2 rounded-lg">
            Edit
          </a>

          <a href="/delete/<%= id %>" 
            class="bg-red-500/80 px-5 py-2 rounded-lg">
            Delete
          </a>

        </div>

      </div>

      <div class="bg-white/10 p-6 rounded-xl">
        <%= filedata %>
      </div>

    </div>

  </div>

</div>